SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=minimax/minimax-m2.7
EMBEDDING_MODEL=openai/text-embedding-3-small

FRONTEND_URL=http://localhost:3000
RESEARCH_STORAGE_BACKEND=json

# LangGraph checkpoint storage. Use memory for local development. Use postgres
# with a Supabase direct or Session Pooler Postgres connection string.
LANGGRAPH_CHECKPOINT_BACKEND=memory
LANGGRAPH_CHECKPOINT_POSTGRES_URL=
LANGGRAPH_CHECKPOINT_SETUP=true

# Local ReAct agent skills. Directory defaults to api/skills when unset.
AGENT_SKILLS_DIR=
AGENT_ENABLED_SKILLS=

# Langfuse observability, disabled by default.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENVIRONMENT=development
LANGFUSE_RELEASE=
LANGFUSE_SAMPLE_RATE=1.0
