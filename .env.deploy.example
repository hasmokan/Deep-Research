# Copy this file to .env on the deployment host before running docker compose.

API_PORT=8000
WEB_PORT=3000
API_BUILD_CONTEXT=./api
WEB_BUILD_CONTEXT=./web
API_ENV_FILE=./api/.env

# Browser-facing backend URL. Use your domain when available.
NEXT_PUBLIC_API_URL=https://hasmodream.com/ds

# Backend CORS origin for the web app.
FRONTEND_URL=https://hasmodream.com

# Public Supabase values used by the Next.js app at build time.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_AUTH_CALLBACK_PATH=/ds/auth/callback
NEXT_PUBLIC_BASE_PATH=/ds

RESEARCH_STORAGE_BACKEND=json

# Local hot-reload Docker mode. Keep these enabled when developing with
# docker-compose.dev.yml on macOS/OrbStack/Docker Desktop.
WATCHFILES_FORCE_POLLING=true
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true

# hasmodream.com /ds deployment example:
# API_PORT=8000
# WEB_PORT=3002
# API_BUILD_CONTEXT=/api
# WEB_BUILD_CONTEXT=/ds
# API_ENV_FILE=/api/.env
# NEXT_PUBLIC_API_URL=https://hasmodream.com/ds
# FRONTEND_URL=https://hasmodream.com
# NEXT_PUBLIC_AUTH_CALLBACK_PATH=/ds/auth/callback
# NEXT_PUBLIC_BASE_PATH=/ds
